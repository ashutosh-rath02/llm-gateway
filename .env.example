APP_NAME=LLM Gateway
ENVIRONMENT=local
LOG_LEVEL=INFO
API_PREFIX=/v1
DEFAULT_PROVIDER=mock
DEFAULT_MODEL=mock-fast-small
OPENAI_DEFAULT_MODEL=gpt-5.4-mini
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/llm_gateway
PROVIDER_TIMEOUT_MS=15000
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
REPAIR_RETRY_ENABLED=true
MAX_REPAIR_ATTEMPTS_PER_MODEL=1
REPAIR_PROMPT_VERSION=repair_v1
STORE_PROMPTS=false
STORE_OUTPUTS=false
HASH_USER_IDS=true
TRACE_PERSISTENCE_ENABLED=true
AUTH_ENABLED=false
AUTH_API_KEYS={"tenant-key":{"name":"tenant-app","role":"tenant","tenant_id":"tenant_123"},"admin-key":{"name":"admin-app","role":"admin"},"feature-key":{"name":"feature-app","role":"tenant","tenant_id":"tenant_123","allowed_features":["support_triage"]}}
